:80 {
  encode gzip zstd

  # /logout — pure HTTP redirect with explicit cookie expiration headers.
  # The login page detects the `_logged_out=1` cachebuster on its next load
  # and clears localStorage there (since we can't clear localStorage from
  # an HTTP response).
  @logout path /logout
  handle @logout {
    header +Set-Cookie "sb-access-token=; Path=/; Max-Age=0; Secure; SameSite=Lax"
    header +Set-Cookie "sb-access-token=; Domain={$COOKIE_DOMAIN}; Path=/; Max-Age=0; Secure; SameSite=Lax"
    header +Set-Cookie "sb-access-token=; Path=/; Max-Age=0"
    header Cache-Control "no-store"
    redir {$LOGOUT_REDIRECT}?_logged_out=1 302
  }

  # /auth/* — SPA. Caddy strips the prefix internally; the Vite build's
  # `base: "/auth/"` keeps asset URLs prefixed for the browser.
  @auth path /auth /auth/*
  handle @auth {
    uri strip_prefix /auth
    root * /srv
    try_files {path} {path}/ /index.html
    file_server
    header /assets/* Cache-Control "public, max-age=31536000, immutable"
    header / Cache-Control "no-cache"
  }

  # Default — anything else hitting this container (which won't normally
  # happen since traefik only routes /auth and /logout here) gets a 404.
  handle {
    respond "Not Found" 404
  }
}
