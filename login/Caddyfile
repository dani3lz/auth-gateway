:80 {
  encode gzip zstd

  # /logout — pure HTTP redirect with explicit cookie expiration headers.
  # The login page detects the `_logged_out=1` cachebuster on its next load
  # and clears localStorage there (since we can't clear localStorage from
  # an HTTP response).
  @logout path /logout
  handle @logout {
    header +Set-Cookie "sb-access-token=; Path=/; Max-Age=0; Secure; SameSite=Lax"
    header +Set-Cookie "sb-access-token=; Domain={$COOKIE_DOMAIN}; Path=/; Max-Age=0; Secure; SameSite=Lax"
    header +Set-Cookie "sb-access-token=; Path=/; Max-Age=0"
    header Cache-Control "no-store"
    redir {$LOGOUT_REDIRECT}?_logged_out=1 302
  }

  # /favicon/manifest.json — Studio links a web manifest from /favicon/manifest.json.
  # Browser fetches it WITHOUT credentials (web-manifest spec default), so the
  # forward-auth validator sees no cookie and returns 401. Serve a minimal stub
  # here to silence the console error.
  @manifest path /favicon/manifest.json
  handle @manifest {
    header Content-Type "application/manifest+json"
    header Cache-Control "public, max-age=86400"
    respond `{"name":"Studio","short_name":"Studio","start_url":"/","display":"standalone"}` 200
  }

  # /api/platform/notifications — Studio polls supabase.com's notifications
  # endpoint. Self-host has no equivalent. Return an empty list so the UI's
  # poll succeeds quietly. Other /api/platform/* paths fall through to Studio
  # because the sidebar relies on those for feature discovery.
  @notifications path /api/platform/notifications*
  handle @notifications {
    header Content-Type "application/json"
    header Cache-Control "no-store"
    respond `[]` 200
  }

  # /auth/* — SPA. Caddy strips the prefix internally; the Vite build's
  # `base: "/auth/"` keeps asset URLs prefixed for the browser.
  @auth path /auth /auth/*
  handle @auth {
    uri strip_prefix /auth
    root * /srv
    try_files {path} {path}/ /index.html
    file_server
    header /assets/* Cache-Control "public, max-age=31536000, immutable"
    header / Cache-Control "no-cache"
  }

  # Default — anything else hitting this container (which won't normally
  # happen since traefik only routes /auth and /logout here) gets a 404.
  handle {
    respond "Not Found" 404
  }
}
