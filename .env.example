# --------------------------------------------------------------------------
# Coolify
# --------------------------------------------------------------------------
# URL where the Coolify dashboard is reachable from this script (usually localhost).
COOLIFY_URL=http://localhost:8000

# Root API token. Coolify dashboard -> Keys & Tokens -> Create New Token (root).
COOLIFY_TOKEN=

# Target project & server UUIDs. List them with:
#   curl -H "Authorization: Bearer $COOLIFY_TOKEN" $COOLIFY_URL/api/v1/projects
#   curl -H "Authorization: Bearer $COOLIFY_TOKEN" $COOLIFY_URL/api/v1/servers
PROJECT_UUID=
SERVER_UUID=

# --------------------------------------------------------------------------
# Domains
# --------------------------------------------------------------------------
# A wildcard A record for *.PARENT_DOMAIN (and any nested subdomains you use)
# must already point at the VPS public IP. Coolify's bundled traefik will
# negotiate Let's Encrypt certs on first request.
PARENT_DOMAIN=example.com

# Supabase Studio (admin UI behind the auth gateway)
SB_HOST=sb.example.com

# Supabase Kong API gateway: /auth/v1, /rest/v1, /realtime/v1, /storage/v1, /graphql/v1
API_HOST=api.example.com

# Auth gateway login UI is mounted at SB_HOST/auth (no separate subdomain needed)
# AUTH_HOST is kept for back-compat — leave blank for path-based deploys.
AUTH_HOST=

# Auth gateway: forward-auth verifier (this repo's validator/ app)
AUTH_VERIFY_HOST=auth-verify.example.com

# MinIO public domains (S3 API + admin console)
S3_HOST=s3.example.com
MINIO_CONSOLE_HOST=minio.example.com

# --------------------------------------------------------------------------
# SMTP — used by Supabase Auth for confirmation/recovery emails
# --------------------------------------------------------------------------
# Many cloud providers block outbound TCP 25/465. Use port 587 (STARTTLS).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com   # MUST equal SMTP_USER for many providers (Hostinger, etc.)
SMTP_SENDER_NAME=Auth

# --------------------------------------------------------------------------
# Google OAuth — Supabase Auth's external Google provider
# --------------------------------------------------------------------------
# Create an OAuth 2.0 Client ID in Google Cloud Console
# (APIs & Services -> Credentials). Authorized redirect URI must be
# exactly GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.com/auth/v1/callback

# --------------------------------------------------------------------------
# Owner email
# --------------------------------------------------------------------------
# Only this email is allowed to use Studio's Authentication > Users delete
# button. Invited teammates get a 403 from the validator if they try.
# Leave empty to disable the per-user delete restriction.
OWNER_EMAIL=

# --------------------------------------------------------------------------
# Branding (baked into the login bundle at build time)
# --------------------------------------------------------------------------
# Shown as the page title and on the login card.
APP_NAME=Auth Gateway

# --------------------------------------------------------------------------
# Standalone installer only (setup-standalone.sh)
#
# These keys are generated automatically on first run if left blank.
# The Coolify installer ignores them (Coolify generates its own equivalents).
# --------------------------------------------------------------------------

# Email Caddy uses to register Let's Encrypt certificates.
LETSENCRYPT_EMAIL=

# Studio basic-auth (Kong protects Studio with these). Auto-generated if blank.
STUDIO_USER=
STUDIO_PASSWORD=

# Logflare (analytics) API tokens. Auto-generated if blank.
LOGFLARE_API_KEY=
LOGFLARE_PRIVATE_ACCESS_TOKEN=

# pg-meta encryption key. Auto-generated if blank.
PG_META_CRYPTO_KEY=
