# --------------------------------------------------------------------------
# Coolify
# --------------------------------------------------------------------------
# URL where the Coolify dashboard is reachable from this script (usually localhost).
COOLIFY_URL=http://localhost:8000

# Root API token. Coolify dashboard -> Keys & Tokens -> Create New Token (root).
COOLIFY_TOKEN=

# Target project & server UUIDs. List them with:
#   curl -H "Authorization: Bearer $COOLIFY_TOKEN" $COOLIFY_URL/api/v1/projects
#   curl -H "Authorization: Bearer $COOLIFY_TOKEN" $COOLIFY_URL/api/v1/servers
PROJECT_UUID=
SERVER_UUID=

# --------------------------------------------------------------------------
# Domains
# --------------------------------------------------------------------------
# A wildcard A record for *.PARENT_DOMAIN (and any nested subdomains you use)
# must already point at the VPS public IP. Coolify's bundled traefik will
# negotiate Let's Encrypt certs on first request.
PARENT_DOMAIN=example.com

# Supabase Studio (admin UI behind the auth gateway)
SB_HOST=sb.example.com

# Supabase Kong API gateway: /auth/v1, /rest/v1, /realtime/v1, /storage/v1, /graphql/v1
API_HOST=api.example.com

# Auth gateway: login page (this repo's login/ app)
AUTH_HOST=auth.example.com

# Auth gateway: forward-auth verifier (this repo's validator/ app)
AUTH_VERIFY_HOST=auth-verify.example.com

# MinIO public domains (S3 API + admin console)
S3_HOST=s3.example.com
MINIO_CONSOLE_HOST=minio.example.com

# --------------------------------------------------------------------------
# SMTP — used by Supabase Auth for confirmation/recovery emails
# --------------------------------------------------------------------------
# Many cloud providers block outbound TCP 25/465. Use port 587 (STARTTLS).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=admin@example.com
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com   # MUST equal SMTP_USER for many providers (Hostinger, etc.)
SMTP_SENDER_NAME=Soltrix
